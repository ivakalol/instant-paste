## Server
PORT=3000
NODE_ENV=production

## Comma-separated allowed browser origins (no trailing slash)
## Example: https://your-domain.example,https://www.your-domain.example
ALLOWED_ORIGINS=https://your-domain.example

## If behind reverse proxy/CDN (Nginx, Cloudflare, etc.)
## Use 1 for one proxy hop, or true to trust all proxies.
TRUST_PROXY=1

## Secrets (set strong random values before deploy)
LARGE_FILE_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
HEALTH_PASSWORD=CHANGE_ME_TO_A_DIFFERENT_LONG_RANDOM_SECRET

## Upload-password brute-force protection
VERIFY_PASSWORD_MAX_ATTEMPTS=5
VERIFY_PASSWORD_WINDOW_MS=300000
VERIFY_PASSWORD_LOCK_MS=600000
